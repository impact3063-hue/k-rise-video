  "parsingRules": {
    "properNounHandling": {
      "rule": "固有名詞は必ず一塊として扱い、内部で分割しない",
      "example": "K-RISE → ['K-RISE'] (NOT ['K', '-', 'R', 'I', 'S', 'E'])"
    },
    "contextualExpressionHandling": {
      "rule": "「とは」等の文脈的表現は固有名詞の後に独立して配置",
      "example": "K-RISEとは → ['K-RISE', 'と', 'は'] OR ['K-RISE', 'とは']"
    },
    "characterTimestampAllocation": {
      "rule": "固有名詞内の各文字にもタイムスタンプを割り当てるが、セグメント分割時は一塊として扱う",
      "example": "K-RISEの各文字 K,R,I,S,E に個別のタイムスタンプを付与しつつ、表示時は一括表示"
    }
  }
