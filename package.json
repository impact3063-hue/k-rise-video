{
  "name": "k-rise-video",
  "version": "1.0.0",
  "description": "My Remotion video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/lib-storage": "^3.1087.0",
    "@remotion/cli": "4.0.486",
    "@remotion/tailwind-v4": "4.0.486",
    "dotenv": "^17.4.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.486",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.486",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "validate": "node scripts/validate-video-data.mjs",
    "generate": "python scripts/generate-master.py",
    "optimize": "python scripts/optimize-params.py",
    "render-batch": "python scripts/generate-master.py && npm run validate && remotion render KRiseTikTok3 out/auto.mp4 --overwrite",
    "package-sns": "node package_sns_assets.js",
    "render": "npm run validate && remotion render AudioDrivenVideo output.mp4",
    "render-tiktok3": "npm run validate && remotion render KRiseTikTok3 out/test.mp4",
    "render-upload": "node scripts/render-and-upload.mjs"
  },
  "sideEffects": [
    "*.css"
  ]
}
