# OpenAI API Key (for make_subtitles_auto.py)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Anthropic API Key (for make_script_auto.py)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key-here

# TikTok API Credentials (for upload_tiktok_auto.py)
# Get your credentials from: https://developers.tiktok.com/
# 1. Create an app at TikTok Developer Portal
# 2. Get OAuth 2.0 access token with video.upload permission
# 3. Get your Open ID from the authorization flow
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token-here
TIKTOK_OPEN_ID=your-tiktok-open-id-here
